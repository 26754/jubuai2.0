{
  "name": "jubuai",
  "productName": "JuBu AI",
  "version": "1.0.0",
  "description": "AI 驱动的动漫/短剧分镜创作工具",
  "author": "MemeCalculate",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/26754/jubuai.git"
  },
  "homepage": "https://github.com/26754/jubuai",
  "bugs": {
    "url": "https://github.com/26754/jubuai/issues"
  },
  "type": "module",
  "browserslist": [
    "last 3 Chrome versions",
    "last 3 Firefox versions",
    "last 3 Safari versions",
    "last 3 Edge versions"
  ],
  "scripts": {
    "dev": "concurrently \"tsx server/api-server.ts\" \"vite --config vite.config.ts\"",
    "dev:simple": "concurrently \"tsx server/api-server.ts\" \"vite --config vite-simple.config.ts\"",
    "build": "vite build --config vite.config.ts",
    "build:simple": "vite build --config vite-simple.config.ts",
    "preview": "vite preview",
    "start": "npx serve dist -l 5000",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
